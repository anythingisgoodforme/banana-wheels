{
  "name": "banana-wheels",
  "version": "1.0.0",
  "description": "First-person JavaScript canvas game prototype with lightweight repo tooling",
  "main": "index.js",
  "scripts": {
    "start": "http-server ./public -p 8000 -o",
    "serve": "http-server ./public -p 8000",
    "dev": "live-server public --port=8000",
    "lint": "eslint \"src/**/*.js\" \"public/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"public/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\" \"public/**/*.js\" \"public/**/*.html\" \"public/**/*.css\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.js\" \"public/**/*.js\" \"public/**/*.html\" \"public/**/*.css\" \"*.json\" \"*.md\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "echo 'Build complete - game is in public/ directory'",
    "pre-commit": "npm run lint:fix && npm run format"
  },
  "keywords": [
    "javascript",
    "games",
    "learning",
    "game-development"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "prettier": "^3.2.5",
    "http-server": "^14.1.1"
  },
  "dependencies": {}
}
